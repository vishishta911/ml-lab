week 5
#model 1 KMEANS
from sklearn.cluster import KMeans
km_model=KMeans(n_clusters=3)
x=iris_df.drop(['target'],axis=1)
km_clusters=km_model.fit_predict(x)
print(km_clusters)
kmeans_centroids=km_model.cluster_centers_
print(kmeans_centroids)
#model2 GMM(EM)
from sklearn.mixture import GaussianMixture
gm_model=GaussianMixture(n_components=3)
gm_clusters=gm_model.fit_predict(x)
gm_clusters
gm_centroid=gm_model.means_
print(gm_centroid)
#compare model1(KMeans) and EM
from sklearn.metrics import silhouette_score
print('KMEANS score is',silhouette_score(x,km_clusters))
print('EM score is',silhouette_score(x,gm_clusters))
if(silhouette_score(x,km_clusters)>silhouette_score(x,gm_clusters)):
    print('kmeans doing better clustering')
else:
    print('em doing better clustering')

#kmeans cluster visualisation
import matplotlib.pyplot as plt
plt.title('KMEANS CLUSTERS')
plt.scatter(x['sepal length (cm)'],x['sepal width (cm)'], c=km_clusters)
plt.show()
#em cluster visualisation
import matplotlib.pyplot as plt
plt.title('EM CLUSTERS')
plt.scatter(x['sepal length (cm)'],x['sepal width (cm)'], c=gm_clusters)
plt.show()



